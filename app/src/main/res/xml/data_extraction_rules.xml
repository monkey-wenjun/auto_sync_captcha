<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for cloud backup.
   Excludes sensitive data like encryption keys and synced messages.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- 排除包含加密密钥的 SharedPreferences -->
        <exclude domain="sharedpref" path="settings.xml"/>
        <!-- 排除同步消息记录 -->
        <exclude domain="sharedpref" path="synced_messages.xml"/>
        <!-- 排除删除消息记录 -->
        <exclude domain="sharedpref" path="deleted_messages.xml"/>
        <!-- 排除永久删除消息记录 -->
        <exclude domain="sharedpref" path="permanently_deleted_messages.xml"/>
        <!-- 排除数据库文件 -->
        <exclude domain="database" path="."/>
    </cloud-backup>
    
    <device-transfer>
        <!-- 设备间传输同样排除敏感数据 -->
        <exclude domain="sharedpref" path="settings.xml"/>
        <exclude domain="sharedpref" path="synced_messages.xml"/>
        <exclude domain="sharedpref" path="deleted_messages.xml"/>
        <exclude domain="sharedpref" path="permanently_deleted_messages.xml"/>
        <exclude domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>
